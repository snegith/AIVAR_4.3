# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database (detector_db — source of truth)
DATABASE_URL=postgresql://detector:detector@localhost:5433/detector_db

# Langfuse's own store on the SAME RDS instance (EC2 deploy only; docker-compose.ec2.yml).
# Local dev uses the postgres container's langfuse_db instead; leave as-is locally.
LANGFUSE_DATABASE_URL=postgresql://detector:detector@localhost:5433/langfuse_db

# LLM provider (auto | groq | stub)
# CI and simulate --dry-run always use stub via LLM_DRY_RUN=true regardless of keys.
LLM_PROVIDER=auto
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
CAPABILITY_JUDGE_CONFIDENCE_THRESHOLD=0.75
# Groq free tier is ~30 RPM; use 3000ms+ between simulate requests to avoid 429s.
SIMULATE_REQUEST_DELAY_MS=500

# Embeddings (fastembed ONNX, 384-dim)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Admin API guard
ADMIN_KEY=change-me-in-production

# Langfuse v2 mirror (optional; off in CI and simulate.py)
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_INGEST_HOST=
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_SECRET_KEY=sk-lf-placeholder
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-placeholder
# On EC2 set this to the public URL: http://EC2_PUBLIC_IP:3000 (ec2_bootstrap.sh writes it).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-change-me
SALT=dev-salt-change-me

# Detection windows
WINDOW_SESSIONS=30
WINDOW_DAYS=7
INACTIVITY_RESET_SECONDS=604800

# Risk scoring
ALERT_THRESHOLD=70
WATCH_THRESHOLD=45
RISK_HALF_LIFE_SECONDS=86400
RISK_ALPHA=0.165
WEIGHT_PROBING=0.35
WEIGHT_ESCALATION=0.35
WEIGHT_ENUMERATION=0.30

# Rate limiting (POST /v1/events per user_id)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=300
RATE_LIMIT_BURST=20

# Probing detector
PROBING_DBSCAN_EPS=0.25
PROBING_DBSCAN_MIN_SAMPLES=4
PROBING_MIN_CLUSTER_SIZE=5
PROBING_MIN_MEAN_SIM=0.75
PROBING_MAX_MEAN_SIM=0.985
PROBING_MIN_BLOCK_RATE=0.6

# Escalation detector
ESCALATION_MIN_RHO=0.6
ESCALATION_MIN_LEVEL_RANGE=2
ESCALATION_MIN_NONDEC_FRAC=0.7
ESCALATION_MIN_SESSIONS=5

# Enumeration detector
ENUMERATION_MIN_GROUP_SIZE=20
ENUMERATION_MIN_DOMINANCE=0.4
ENUMERATION_MIN_REGULARITY=0.7
ENUMERATION_MIN_MEAN_SIM=0.9
ENUMERATION_MIN_COVERAGE=0.6
