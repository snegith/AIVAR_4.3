# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database (detector_db — source of truth)
DATABASE_URL=postgresql://detector:detector@localhost:5433/detector_db

# LLM (real Claude in production; stub only with --dry-run in dev/CI)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-3-5-haiku-latest
LLM_TIMEOUT_SECONDS=30

# Embeddings (fastembed ONNX, 384-dim)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Admin API guard
ADMIN_KEY=change-me-in-production

# Langfuse v2 mirror (optional; off in CI and simulate.py)
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_SECRET_KEY=sk-lf-placeholder
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-placeholder

# Detection windows
WINDOW_SESSIONS=30
WINDOW_DAYS=7
INACTIVITY_RESET_SECONDS=604800

# Risk scoring
ALERT_THRESHOLD=70
WATCH_THRESHOLD=45
RISK_HALF_LIFE_SECONDS=86400
RISK_ALPHA=0.6
WEIGHT_PROBING=0.35
WEIGHT_ESCALATION=0.35
WEIGHT_ENUMERATION=0.30

# Rate limiting (POST /v1/events per user_id)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=300
RATE_LIMIT_BURST=20
